{
  "name": "mcp-doc-processor",
  "version": "1.0.0",
  "description": "MCP server for reading and processing PDF, DOCX, Excel files with intelligent OCR, layout analysis, and document generation capabilities",
  "main": "src/index.js",
  "type": "module",
  "scripts": {
    "start": "node src/index.js",
    "test": "node test/integration.js",
    "test:ocr": "node test/test-ocr-improvements.js",
    "test:styling": "node --test test/test-styling.js",
    "test:create": "node --test test/create-tools.js",
    "test:patch": "node --test test/test-docx-patch.js",
    "test:category": "node test/test-category-registry.js",
    "test:dna": "node test/test-dna.js",
    "test:innovations": "node --test test/test-innovations.js",
    "test:drift": "node --test test/test-drift-internals.js",
    "lint:no-console-log": "! grep -rn 'console\\.log(' src/ --include='*.js'"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.25.2",
    "docx": "^9.5.1",
    "jszip": "^3.10.1",
    "mammoth": "^1.5.4",
    "marked": "^17.0.2",
    "pdf-parse": "^2.4.5",
    "xlsx": "^0.18.5",
    "xlsx-js-style": "^1.2.0"
  }
}
