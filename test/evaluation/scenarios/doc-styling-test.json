        {
          "name": "First document created successfully",
          "check": "result.success === true",
          "expected": "success: true"
        },
        {
          "name": "First document file path is valid",
          "check": "result.filePath && result.filePath.endsWith('.docx')",
          "expected": "filePath: string ending with .docx"
        },
        {
          "name": "First document style preset applied",
          "check": "result.stylePreset === 'professional'",
          "expected": "stylePreset: 'professional'"
        },
        {
          "name": "Second document created successfully",
          "check": "result2.success === true",
          "expected": "success: true"
        },
        {
          "name": "Second document style preset applied",
          "check": "result2.stylePreset === 'professional'",
          "expected": "stylePreset: 'professional'"
        },
        {
          "name": "Third document created successfully",
