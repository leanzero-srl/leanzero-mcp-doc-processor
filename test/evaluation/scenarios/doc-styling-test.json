    {
      "name": "Test 4: Document Styling - Custom Styling Overrides",
      "description": "Test custom styling overrides to verify they take precedence over preset values",
      "testType": "custom-styling",
      "params": {
        "title": "Custom Styling Test Document",
        "paragraphs": [
          "This document uses custom styling overrides.",
          "Custom settings should override the base preset."
        ],
        "outputPath": "./test/output/test-styling-custom.docx",
        "preventDuplicates": false,
        "stylePreset": "professional",
        "style": {
          "font": {
            "size": 14,
            "color": "FF0000",
            "bold": true
          },
          "paragraph": {
            "spacingBefore": 300,
            "spacingAfter": 300,
            "lineSpacing": 1.5
          }
        }
      },
      "expectedOutput": {
        "success": true,
        "filePath": "string ending with .docx",
        "stylePreset": "professional",
        "styleConfig": {
          "font": {
            "family": "string",
            "size": 14,
            "color": "FF0000",
            "bold": true
          },
          "paragraph": {
            "alignment": "string",
            "spacingBefore": 300,
            "spacingAfter": 300,
            "lineSpacing": 1.5
          }
        },
        "message": "string containing 'WRITTEN TO DISK'"
      },
      "checks": [
        {
          "name": "Document created successfully",
          "check": "result.success === true",
          "expected": "success: true"
        },
        {
          "name": "Custom font size applied",
          "check": "result.styleConfig.font.size === 14",
          "expected": "font.size: 14 (custom override)"
        },
        {
          "name": "Custom font color applied",
          "check": "result.styleConfig.font.color === 'FF0000'",
          "expected": "font.color: 'FF0000' (custom override)"
        },
        {
          "name": "Custom paragraph spacing applied",
          "check": "result.styleConfig.paragraph.spacingBefore === 300",
          "expected": "paragraph.spacingBefore: 300 (custom override)"
        },
        {
          "name": "Custom line spacing applied",
          "check": "result.styleConfig.paragraph.lineSpacing === 1.5",
          "expected": "paragraph.lineSpacing: 1.5 (custom override)"
        }
      ],
      "qualityMetrics": {
        "success": true,
        "customFontSizeApplied": true,
        "customFontColorApplied": true,
        "customParagraphSpacingApplied": true,
        "customLineSpacingApplied": true
      }
