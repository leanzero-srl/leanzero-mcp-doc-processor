  "description": "Comprehensive test scenario for document styling functionality, testing style application, style preservation, and styling consistency across various document types and configurations.",
  "category": "styling",
  "version": "1.0.0",
  "author": "MCP Test Framework",
  "created": "2024-01-15",
  "relatedTests": ["test/test-styling.js"],
  "steps": [
    {
      "name": "Test 1: Document Styling - Basic Style Application",
      "description": "Test basic document styling with a single style preset applied to a simple document",
      "testType": "basic-styling",
      "params": {
        "title": "Professional Report - Basic Styling Test",
        "paragraphs": [
          "This document demonstrates basic styling with the professional style preset applied.",
          "All text should be formatted according to the professional style settings.",
          "The document should have consistent styling throughout."
        ],
        "outputPath": "./test/output/test-styling-basic.docx",
        "preventDuplicates": false,
        "stylePreset": "professional"
      },
      "expectedOutput": {
        "success": true,
        "filePath": "string ending with .docx",
        "stylePreset": "professional",
        "styleConfig": {
          "font": {
            "family": "string",
            "size": "number",
            "color": "string"
          },
          "paragraph": {
            "alignment": "string",
            "spacingBefore": "number",
            "spacingAfter": "number",
            "lineSpacing": "number"
          }
        },
        "message": "string containing 'WRITTEN TO DISK'"
      },
      "checks": [
        {
          "name": "Document created successfully",
          "check": "result.success === true",
          "expected": "success: true"
        },
        {
          "name": "File path is valid",
          "check": "result.filePath && result.filePath.endsWith('.docx')",
          "expected": "filePath: string ending with .docx"
        },
        {
          "name": "Style preset applied",
          "check": "result.stylePreset === 'professional'",
          "expected": "stylePreset: 'professional'"
        },
        {
          "name": "Style configuration present",
          "check": "result.styleConfig !== undefined",
          "expected": "styleConfig: object"
        },
        {
          "name": "Message contains disk write confirmation",
          "check": "result.message && result.message.includes('WRITTEN TO DISK')",
          "expected": "message contains 'WRITTEN TO DISK'"
        }
      ],
      "qualityMetrics": {
        "success": true,
        "validFilePath": true,
        "stylePresetApplied": true,
        "styleConfigPresent": true,
        "messageFormatCorrect": true
      }
    },
