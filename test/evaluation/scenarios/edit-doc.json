{
  "name": "edit-doc",
  "description": "Model edits an existing document using edit-doc tool with append and replace actions",
  "steps": [
    {
      "name": "Tool selection",
      "check": "Tool name is 'edit-doc'",
      "validate": "toolName === 'edit-doc'"
    },
    {
      "name": "Action validation - append",
      "check": "Action is 'append' to add content",
      "validate": "params.action === 'append'"
    },
    {
      "name": "File path validation",
      "check": "Document path is specified and exists",
      "validate": "params.filePath && params.filePath.length > 0"
    },
    {
      "name": "Response format - append",
      "check": "Response contains success status and file path",
      "validate": "result.success === true && result.filePath && result.filePath.endsWith('.docx')"
    },
    {
      "name": "Action confirmation",
      "check": "Response confirms append action",
      "validate": "result.action === 'append'"
    },
    {
      "name": "Formatting preserved check",
      "check": "Response indicates formatting was preserved",
      "validate": "result.formattingPreserved === true || result.legacyMode === false"
    },
    {
      "name": "Content append verification",
      "check": "Response shows paragraphs and tables were appended",
      "validate": "result.paragraphsAppended > 0 || result.tablesAppended > 0"
    },
    {
      "name": "Action validation - replace",
      "check": "Action is 'replace' to overwrite content",
      "validate": "params.action === 'replace'"
    },
    {
      "name": "Response format - replace",
      "check": "Response contains success status and file path",
      "validate": "result.success === true && result.filePath && result.filePath.endsWith('.docx')"
    },
    {
      "name": "Action confirmation - replace",
      "check": "Response confirms replace action",
      "validate": "result.action === 'replace'"
    },
    {
      "name": "Structure preserved check",
      "check": "Response indicates structure was preserved",
      "validate": "result.structurePreserved === true || result.legacyMode === false"
    },
    {
      "name": "Content replacement verification",
      "check": "Response shows paragraphs and tables were replaced",
      "validate": "result.paragraphsReplaced > 0 || result.tablesReplaced > 0"
    },
    {
      "name": "Style configuration check",
      "check": "Response includes style preset information",
      "validate": "result.stylePreset !== undefined"
    },
    {
      "name": "Message format",
      "check": "Message contains success message and file path",
      "validate": "result.message && (result.message.includes('UPDATED') || result.message.includes('REPLACED')) && result.message.includes('docx')"
    }
  ],
  "expectedOutput": {
    "append": {
      "success": true,
      "filePath": "string ending with .docx",
      "action": "append",
      "formattingPreserved": true,
      "paragraphsAppended": "number >= 0",
      "tablesAppended": "number >= 0",
      "documentStructure": {
        "hasHeaders": "boolean",
        "hasFooters": "boolean",
        "hasImages": "boolean"
      },
      "registryEntry": {
        "id": "string or null",
        "category": "string"
      },
      "message": "string containing 'UPDATED' and 'docx'"
    },
    "replace": {
      "success": true,
      "filePath": "string ending with .docx",
      "action": "replace",
      "structurePreserved": true,
      "paragraphsReplaced": "number >= 0",
      "tablesReplaced": "number >= 0",
      "registryEntry": {
        "id": "string or null",
        "category": "string"
      },
      "message": "string containing 'REPLACED' and 'docx'"
    }
  },
  "qualityMetrics": {
    "successStatus": true,
    "filePathValid": true,
    "actionConfirmed": true,
    "formattingPreserved": true,
    "contentUpdated": true,
    "styleConfigured": true,
    "messageFormatCorrect": true,
    "registryUpdated": true
  },
  "baseline": "edit-doc",
  "testData": {
    "testDocument": {
      "title": "Edit Doc Test Document",
      "paragraphs": [
        "This is the original content of the document.",
        "It contains multiple paragraphs with various formatting.",
        "This document will be edited using the edit-doc tool."
      ],
      "tables": [
        [
          ["Column 1", "Column 2"],
          ["Data 1", "Data 2"]
        ]
      ],
      "outputPath": "./test/output/edit-doc-test.docx"
    },
    "appendContent": {
      "paragraphs": [
        "This is appended content.",
        "It preserves the original document formatting."
      ],
      "tables": [
        [
          ["New Column 1", "New Column 2"],
          ["New Data 1", "New Data 2"]
        ]
      ]
    },
    "replaceContent": {
      "title": "Replaced Document Title",
      "paragraphs": [
        "This is the completely replaced content.",
        "Original content has been overwritten."
      ],
      "tables": [
        [
          ["Replaced Column 1", "Replaced Column 2"],
          ["Replaced Data 1", "Replaced Data 2"]
        ]
      ]
    }
  },
  "setupInstructions": [
    "1. Create test output directory: mkdir -p test/output",
    "2. Create a test document using create-doc with title 'Edit Doc Test Document'",
    "3. Note the file path for testing edit-doc",
    "4. Prepare append content with paragraphs and tables",
    "5. Prepare replace content with new title, paragraphs, and tables"
  ],
  "cleanupInstructions": [
    "1. Remove test documents from test/output/edit-doc-test.docx",
    "2. Clean up any registry entries created during testing",
    "3. Remove any temporary files created during testing"
  ],
  "testScenarios": [
    {
      "name": "test-append-content",
      "description": "Test appending content to an existing document",
      "setup": "Create a test document using create-doc with initial content",
      "params": {
        "filePath": "./test/output/edit-doc-test.docx",
        "action": "append",
        "paragraphs": [
          "This is appended content.",
          "It preserves the original document formatting."
        ],
        "tables": [
          [
            ["New Column 1", "New Column 2"],
            ["New Data 1", "New Data 2"]
          ]
        ],
        "addSeparator": true,
        "category": "test"
      },
      "expected": {
        "success": true,
        "action": "append",
        "formattingPreserved": true,
        "paragraphsAppended": 2,
        "tablesAppended": 1,
        "messageContains": ["UPDATED", "docx"]
      },
      "validation": [
        "result.success === true",
        "result.action === 'append'",
        "result.formattingPreserved === true",
        "result.paragraphsAppended === 2",
        "result.tablesAppended === 1"
      ]
    },
    {
      "name": "test-replace-content",
      "description": "Test replacing content in an existing document",
      "setup": "Create a test document using create-doc with initial content",
      "params": {
        "filePath": "./test/output/edit-doc-test.docx",
        "action": "replace",
        "title": "Replaced Document Title",
        "paragraphs": [
          "This is the completely replaced content.",
          "Original content has been overwritten."
        ],
        "tables": [
          [
            ["Replaced Column 1", "Replaced Column 2"],
            ["Replaced Data 1", "Replaced Data 2"]
          ]
        ],
        "category": "test"
      },
      "expected": {
        "success": true,
        "action": "replace",
        "structurePreserved": true,
        "paragraphsReplaced": 2,
        "tablesReplaced": 1,
        "messageContains": ["REPLACED", "docx"]
      },
      "validation": [
        "result.success === true",
        "result.action === 'replace'",
        "result.structurePreserved === true",
        "result.paragraphsReplaced === 2",
        "result.tablesReplaced === 1"
      ]
    },
    {
      "name": "test-append-with-style",
      "description": "Test appending content with custom style preset",
      "setup": "Create a test document using create-doc with initial content",
      "params": {
        "filePath": "./test/output/edit-doc-test.docx",
        "action": "append",
        "paragraphs": ["Content with style preset"],
        "stylePreset": "professional",
        "category": "test"
      },
      "expected": {
        "success": true,
        "action": "append",
        "stylePreset": "professional",
        "messageContains": ["UPDATED", "professional"]
      },
      "validation": [
        "result.success === true",
        "result.action === 'append'",
        "result.stylePreset === 'professional'"
      ]
    },
    {
      "name": "test-invalid-file-path",
      "description": "Test error handling for non-existent file",
      "setup": "Use a non-existent file path",
      "params": {
        "filePath": "./test/output/non-existent-file.docx",
        "action": "append",
        "paragraphs": ["Test content"]
      },
      "expected": {
        "success": false,
        "error": "File not found",
        "messageContains": ["File not found"]
      },
      "validation": [
        "result.success === false",
        "result.error && result.error.includes('File not found')",
        "result.message && result.message.includes('File not found')"
      ]
    },
    {
      "name": "test-invalid-action",
      "description": "Test error handling for invalid action",
      "setup": "Use an invalid action value",
      "params": {
        "filePath": "./test/output/edit-doc-test.docx",
        "action": "invalid-action",
        "paragraphs": ["Test content"]
      },
      "expected": {
        "success": false,
        "error": "Invalid action",
        "messageContains": ["Invalid action"]
      },
      "validation": [
        "result.success === false",
        "result.error && result.error.includes('Invalid action')",
        "result.message && result.message.includes('Invalid action')"
      ]
    }
  ]
}
