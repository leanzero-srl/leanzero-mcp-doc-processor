        "sheetsCount": ">= 1",
        "tableRows": ">= 2"
      }
    },
    {
      "name": "Test 12: Extract E2E sections",
      "check": "Extract sections from E2E document",
      "action": "extract_sections",
      "validate": "e2eSectionsExtracted === true",
      "expected": {
        "sheetsCount": ">= 1"
      }
    },
    {
      "name": "Test 12: Create E2E source 2 document",
      "check": "Create second E2E source document",
      "action": "create",
      "validate": "e2eSource2Created === true",
      "expected": {
        "success": true
      }
    },
    {
      "name": "Test 12: Assemble E2E documents",
      "check": "Assemble E2E documents",
      "action": "assemble",
      "validate": "e2eAssemblySuccessful === true",
      "expected": {
        "success": true,
        "sourceCount": 2
      }
    },
    {
      "name": "Test 12: Compute E2E fingerprint",
      "check": "Compute fingerprint of assembled E2E document",
      "action": "compute_fingerprint",
      "validate": "e2eFingerprintComputed === true",
      "expected": {
        "wordCount": "> 0"
      }
    },
    {
      "name": "Test 12: Cleanup E2E test",
      "check": "Delete E2E blueprint after testing",
      "action": "cleanup",
      "validate": "e2eCleanupComplete === true",
      "expected": {
        "blueprintDeleted": true
      }
    }
