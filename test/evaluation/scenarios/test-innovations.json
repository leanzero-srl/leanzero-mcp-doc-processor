        "hasSections": true,
        "hasTables": true
      }
    },
    {
      "name": "Test 12: Save E2E blueprint",
      "check": "Save E2E blueprint",
      "action": "save_blueprint",
      "validate": "e2eBlueprintSaved === true",
      "expected": {
        "saveSuccess": true,
        "blueprintName": "e2e-report"
      }
    },
    {
      "name": "Test 12: Load E2E blueprint",
      "check": "Load E2E blueprint",
      "action": "load_blueprint",
      "validate": "e2eBlueprintLoaded === true",
      "expected": {
        "loadSuccess": true
      }
    },
    {
      "name": "Test 12: Extract E2E tables",
      "check": "Extract tables from E2E document",
      "action": "extract_tables",
      "validate": "e2eTablesExtracted === true",
